  procedures :
   -
     name : OpenOrEnablePane
     procedure_id : 1848135229312302906
     type_code : 14
     code : |1-
      // Summary: Open a window in a pane of the dynamic tab
      // Syntax:
      //OpenOrEnablePane (<sWindowName> is string, <sCaption> [, ...])
      //
      // Parameters:
      //	sWindowName (ANSI string): Name of the window to open
      //	sCaption: Pane caption
      // 	<*>: Parameters of the window
      // Return value:
      // 	None
      
      Procédure OpenOrEnablePane(sWindowName is string<window name>, sCaption,  *)
      
      sAlias is string=sWindowName+sCaption
      
      // CTRL key down
      bEnabled is boolean=not KeyPressed(kpControl)
      
      // current pane
      sCurrentAlias is string=TAB_Main
      
      // disables the display
      MyWindow..DisplayEnabled=False
      
      // if the pane does not exist yet
      if TabStatus(TAB_Main,sAlias)=paneNotFound then
      	// open a new pane
      	NewTab is Control <- TabOpen(TAB_Main,sCaption,sWindowName,MyParameters[3 to])
      	NewTab..Alias=sAlias
      
      	// otherwise, enable the tab
      else if bEnabled
      	TAB_Main=sAlias
      end
      
      // if the pane must not be enabled (CTRL key down)
      if not bEnabled then
      	TAB_Main=sCurrentAlias
      end
      
      // enables the display
      MyWindow..DisplayEnabled=True
     type : 458752
