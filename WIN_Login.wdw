  type_code : 1
  p_codes :
   -
     code : |1-
      PROCEDURE MyWindow()
      mywindow..ReturnedValue	= faux
      DIRECCION:
      HLitRecherche(LocalParams,Param,"SERVIDOR")
      SI HTrouve(LocalParams) alors
      	
      SINON
      	si OuiNon("No se encuentra una dirección del servidor, desea ingresarla?") alors
      		si Open(WIN_Configuración) alors
      			GOTO DIRECCION
      		SINON
      			Error("Debe ingresar una dirección para la conexión con el servidor")
      			Ferme()
      		FIN
      	FIN
      FIN
