 code_elements :
  type_code : 1
  p_codes :
   -
     code : |1-
      PROCEDURE MyWindow()
      mywindow..ReturnedValue	= faux
      DIRECCION:
      HLitRecherche(LocalParams,Param,"SERVIDOR")
      SI HTrouve(LocalParams) alors
      	IP_SERVIDOR	= LocalParams.Value
      
      SINON
      	si OuiNon("No se encuentra una dirección del servidor, dicha dirección es necesaria para iniciar el sistema","Desea ingresarla?") alors
      		si Open(WIN_Configuración) alors
      			GOTO DIRECCION
      		SINON
      			Error("Debe ingresar una dirección para la conexión con el servidor")
      			Ferme()
      		FIN
      	SINON
      		Ferme()
      	FIN
      FIN
