  -
    name : BTN_Ingresar
    identifier : 0x29a758d603ee1a31
    internal_properties : 
    properties :
     x : 140
     y : 348
     width : 150
     height : 36
     accelerator_key : 65535
     tab_order : 2
    style : {}
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         STC_ErrorMsg..Visible	= faux
         si SansEspace(EDT_Usuario)="" alors
         	STC_ErrorMsg			= "Ingrese un nombre de usuario válido"
         	STC_ErrorMsg..Visible	= Vrai
         	InvalidInputShowMessage(EDT_Usuario,"")
         	SetFocusAndReturnToUserInput(EDT_Usuario)
         FIN
         SI SansEspace(EDT_Contraseña)="" ALORS
         	STC_ErrorMsg			= "Ingrese una contraseña"
         	STC_ErrorMsg..Visible	= Vrai
         	InvalidInputShowMessage(EDT_Contraseña,"")
         	SetFocusAndReturnToUserInput(EDT_Contraseña)
         FIN
         
         //Recupera el hash del usuario desde el WebService
         hash	is Buffer	= ""
         JSONreq	is json
         WSreq	is httpRequest
         WSres	is httpResponse
         
         JSONreq.username	= EDT_Usuario
         
         WSreq.ContentType	= mimeTypeJSON
         WSreq.Content		= JSONreq
         WSreq.Method		= httpGet
         
         WSres	= WSreq.send()
         response is json = stringtojson(WSres.Content)
         si WSres.StatusCode<>200 alors
         	STC_ErrorMsg			= "Error al comunicarse con el servidor"
         	STC_ErrorMsg..Visible	= Vrai
         	return
         FIN
         
         si HashCheckString(HA_SHA_256,EDT_Contraseña,hash) alors
         	//Login exitoso
         	WSreq.Method	= httpPut
         	JSONreq.IDUser	= response.ID
         sinon
         	//Contraseña incorrecta
         	STC_ErrorMsg			= "Contraseña incorrecta"
         	STC_ErrorMsg..Visible	= vrai
         	InvalidInputShowMessage(EDT_Contraseña,"")
         	SetFocusAndReturnToUserInput(EDT_Contraseña)
         FIN
        type : 18
      -
        type : 161
        enabled : false
